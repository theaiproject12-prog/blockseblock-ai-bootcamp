# =============================================================================
# AI Engineering Bootcamp — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — your API keys must stay private.
#
# Quick start: choose ONE provider below, fill in its section, and set
# LLM_PROVIDER to the matching value. Leave all other sections blank.
# See docs/provider-setup-guide.md for detailed instructions.
# =============================================================================


# =============================================================================
# PROVIDER ROUTING (required)
# =============================================================================

# Which provider to use for chat, RAG, and agents.
# Options: groq | openai | anthropic | cohere | ollama | azure | bedrock | vertex | custom
#
# groq  — recommended for beginners: free tier, no credit card, very fast.
#          Get a free key at console.groq.com in under 2 minutes.
LLM_PROVIDER=ollama

# Optional: use a different provider for voice (STT/TTS) in Feature 10.
# Only needed if your main LLM_PROVIDER doesn't support speech (e.g. anthropic,
# cohere, ollama). Leave blank to use the same provider as LLM_PROVIDER.
VOICE_PROVIDER=

# Optional: use a separate provider for image understanding (Feature 10 Vision).
# Leave blank if you don't need image input.
VLM_PROVIDER=


# =============================================================================
# GROQ  (free tier — recommended for beginners)
# Get your key at: console.groq.com  (no credit card required)
# =============================================================================

#GROQ_API_KEY=
#GROQ_MODEL=llama-3.3-70b-versatile


# =============================================================================
# OPENAI  (use when LLM_PROVIDER=openai or VOICE_PROVIDER=openai)
# Get your key at: platform.openai.com/api-keys
# =============================================================================

OPENAI_API_KEY=

# The model name to use. Examples: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini


# =============================================================================
# ANTHROPIC  (use when LLM_PROVIDER=anthropic)
# Get your key at: console.anthropic.com
# =============================================================================

ANTHROPIC_API_KEY=

# The model name to use. Examples: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6


# =============================================================================
# COHERE  (use when LLM_PROVIDER=cohere)
# Get your key at: dashboard.cohere.com  (free trial available)
# =============================================================================

COHERE_API_KEY=

# The model name to use. Examples: command-r-plus, command-r, command
COHERE_MODEL=command-r-plus


# =============================================================================
# OLLAMA — local SLM, no API key needed  (use when LLM_PROVIDER=ollama)
# Install from: https://ollama.com  |  Then run: ollama pull llama3.1
# =============================================================================

# URL where your local Ollama server is running.
OLLAMA_BASE_URL=http://localhost:11434

# The model name you've pulled with `ollama pull <model>`.
# Good starting choices: llama3.1 (best all-round), qwen2.5 (good tool calling),
#                        phi3 (lightweight, fast on CPU)
OLLAMA_MODEL=llama3.1


# =============================================================================
# AZURE OPENAI  (use when LLM_PROVIDER=azure)
# Set up at: portal.azure.com → Azure OpenAI
# =============================================================================

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
# The deployment name you created in Azure AI Studio (not the model name)
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-02-01


# =============================================================================
# AWS BEDROCK  (use when LLM_PROVIDER=bedrock)
# Requires an AWS account with Bedrock model access enabled
# =============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Examples: anthropic.claude-3-sonnet-20240229-v1:0, meta.llama3-70b-instruct-v1:0
BEDROCK_MODEL_ID=


# =============================================================================
# GCP VERTEX AI  (use when LLM_PROVIDER=vertex)
# Requires a GCP project with Vertex AI API enabled
# =============================================================================

GCP_PROJECT_ID=
GCP_REGION=us-central1
# Examples: gemini-1.5-pro, gemini-1.5-flash
VERTEX_MODEL=


# =============================================================================
# CUSTOM — any other OpenAI-compatible endpoint  (use when LLM_PROVIDER=custom)
# Works for: Together AI, Fireworks, Mistral, local vLLM servers, etc.
# =============================================================================

CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_MODEL=


# =============================================================================
# VECTOR DATABASE  (required from Feature 5 — Chunking & Embeddings)
# =============================================================================

# Folder on disk where document embeddings are stored.
VECTOR_DB_PATH=./data/vectordb

# The embedding model to use when converting text to vectors.
# Examples: text-embedding-3-small (OpenAI, cheaper), text-embedding-3-large (higher quality)
EMBEDDING_MODEL=text-embedding-3-small


# =============================================================================
# FEATURE 10 — Voice + Vision
# =============================================================================

# STT model for speech-to-text.
# Examples: whisper-large-v3 (Groq — fast & free), whisper-1 (OpenAI)
STT_MODEL=whisper-large-v3

# TTS model for text-to-speech. Leave blank if not using voice output.
# Examples: tts-1 (OpenAI), tts-1-hd (OpenAI, higher quality)
TTS_MODEL=

# VLM model for image understanding (used when VLM_PROVIDER is set).
# Ollama example: llava or phi3:vision
# OpenAI example: gpt-4o
VLM_MODEL=llava


# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Port the FastAPI server listens on. Change if 8000 is already in use.
APP_PORT=8000

# Hostname to bind to. 0.0.0.0 = accept from any address (correct for Docker).
APP_HOST=0.0.0.0


# =============================================================================
# SESSION MANAGEMENT  (Feature 3+ — Conversation Memory)
# =============================================================================

SESSION_TTL_SECONDS=3600


# =============================================================================
# RATE LIMITING  (Feature 12 — Production Polish)
# =============================================================================

RATE_LIMIT_PER_MINUTE=60


# =============================================================================
# DOMAIN / ASSISTANT IDENTITY  (customize for your project)
# =============================================================================

ASSISTANT_NAME=My AI Assistant
ASSISTANT_DESCRIPTION=You are a helpful assistant. Replace this with your domain description.
